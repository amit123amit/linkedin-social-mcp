# LinkedIn OAuth 2.0 App Credentials
# Create your app at: https://www.linkedin.com/developers/apps
# Required Product: "Share on LinkedIn"
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Redirect URI — must match exactly what you set in your LinkedIn app settings
LINKEDIN_REDIRECT_URI=http://localhost:3000/callback

# Optional: custom token storage path (default: ~/.linkedin-social-mcp/tokens.json)
# TOKEN_STORAGE_PATH=/path/to/tokens.json
